{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://tbigtlfuittunagpyoxk.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "getweb-task-mcp",
      "version": "0.1.0",
      "title": "GetWeb Task"
    },
    "tools": [
      {
        "name": "list_my_tasks",
        "title": "List my tasks",
        "description": "List tasks belonging to the signed-in user. Optional filters by date (YYYY-MM-DD) or status.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "date": {
              "description": "Filter by date (YYYY-MM-DD)",
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": [
                "Not Started",
                "In Progress",
                "Finished"
              ]
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "create_task",
        "title": "Create task",
        "description": "Create a task for the signed-in user.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "description": {
              "type": "string"
            },
            "category": {
              "description": "Task category e.g. Development, Design, Video, Ads",
              "type": "string"
            },
            "date": {
              "type": "string",
              "description": "Date in YYYY-MM-DD"
            },
            "target_minutes": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "title",
            "date"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "complete_task",
        "title": "Complete task",
        "description": "Mark a task as Finished, stop any open timer, and optionally attach completion notes and a project link.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "task_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            },
            "completion_notes": {
              "type": "string"
            },
            "project_link": {
              "type": "string",
              "format": "uri"
            }
          },
          "required": [
            "task_id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "start_timer",
        "title": "Start timer",
        "description": "Start a time session on one of the signed-in user's tasks and set it to In Progress.",
        "annotations": {
          "readOnlyHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "task_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            }
          },
          "required": [
            "task_id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "stop_timer",
        "title": "Stop timer",
        "description": "Stop the currently open time session on the signed-in user's task.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "task_id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            }
          },
          "required": [
            "task_id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "team_activity",
        "title": "Team activity snapshot",
        "description": "Get the current team activity snapshot (admin only). Returns each member's active task and today's todo/progress/completed lists.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
